{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "debug cmd: doctor",
      "type": "go",
      "request": "launch",
      "mode": "exec",
      "debugAdapter": "dlv-dap",
      "host": "127.0.0.1",
      "port": 40000,
      "preLaunchTask": "make dev-dlv",
      "substitutePath": [{ "from": "${workspaceFolder:pfs-project}", "to": "/workspace" }],
      "program": "/workspace/bin/pfs",
      "args": ["--config", "/workspace/configs/dev.yaml", "doctor"]
    },
    {
      "name": "debug cmd: mount",
      "type": "go",
      "request": "launch",
      "mode": "exec",
      "debugAdapter": "dlv-dap",
      "host": "127.0.0.1",
      "port": 40000,
      "preLaunchTask": "make dev-dlv",
      "substitutePath": [{ "from": "${workspaceFolder:pfs-project}", "to": "/workspace" }],
      "program": "/workspace/bin/pfs",
      "args": ["mount", "media"]
    },
    {
      "name": "debug cmd: index",
      "type": "go",
      "request": "launch",
      "mode": "exec",
      "debugAdapter": "dlv-dap",
      "host": "127.0.0.1",
      "port": 40000,
      "preLaunchTask": "make dev-dlv",
      "substitutePath": [{ "from": "${workspaceFolder:pfs-project}", "to": "/workspace" }],
      "program": "/workspace/bin/pfs",
      "args": ["index", "media"]
    },
    {
      "name": "debug test: unit : cli",
      "type": "go",
      "request": "launch",
      "mode": "exec",
      "debugAdapter": "dlv-dap",
      "host": "127.0.0.1",
      "port": 40010,
      "preLaunchTask": "make dev-dlv-test",
      "substitutePath": [{ "from": "${workspaceFolder:pfs-project}", "to": "/workspace" }],
      "program": "/workspace/bin/pfs.unit.cli",
      "args": ["-test.v"]
    },
    {
      "name": "debug test: integration",
      "type": "go",
      "request": "launch",
      "mode": "exec",
      "debugAdapter": "dlv-dap",
      "host": "127.0.0.1",
      "port": 40020,
      "preLaunchTask": "make dev-dlv-test-integration",
      "substitutePath": [{ "from": "${workspaceFolder:pfs-project}", "to": "/workspace" }],
