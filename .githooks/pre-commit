#!/usr/bin/env bash
set -euo pipefail

DCD=${DCD:-"docker compose -f docker-compose.dev.yaml"}

if ! $DCD ps -q dev >/dev/null 2>&1 || [[ -z "$($DCD ps -q dev 2>/dev/null || true)" ]]; then
  echo "pre-commit: dev container is not running. Run 'make dev' first." >&2
  exit 1
fi

make fmt-staged

staged_keep=()
while IFS= read -r f; do
  [[ -n "$f" ]] && staged_keep+=("$f")
done < <(git diff --name-only --cached --diff-filter=ACMR)

if ((${#staged_keep[@]} > 0)); then
  git add -- "${staged_keep[@]}"
fi

make lint-staged
