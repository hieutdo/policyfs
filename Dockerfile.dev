FROM golang:1.26.2-trixie

RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    pkg-config \
    python3 \
    python3-venv \
    python3-pip \
    fuse3 \
    libfuse3-dev \
    inotify-tools \
    lcov \
    sqlite3 \
    shfmt \
    nodejs \
    npm \
    util-linux \
    e2fsprogs \
    xfsprogs \
    procps \
    git \
    make \
    bash \
    && rm -rf /var/lib/apt/lists/*

RUN go install golang.org/x/tools/cmd/goimports@latest \
    && go install github.com/air-verse/air@latest \
    && go install github.com/go-delve/delve/cmd/dlv@latest \
    && go install github.com/wadey/gocovmerge@latest \
    && go install github.com/jandelgado/gcov2lcov@latest \
    && npm install -g prettier@3

RUN curl -sSfL https://golangci-lint.run/install.sh | sh -s -- -b $(go env GOPATH)/bin v2.10.1

RUN echo "user_allow_other" >> /etc/fuse.conf

RUN echo "alias l='ls -al'" >> /root/.bashrc

RUN mkdir -p /var/lib/pfs-disks /mnt/ssd1 /mnt/ssd2 /mnt/hdd1 /mnt/hdd2 /mnt/hdd3 /mnt/pfs/media

ENV PATH="/workspace/bin:/workspace/scripts:/go/bin:/usr/local/go/bin:/usr/local/bin:/usr/bin:${PATH}" \
    PFS_CONFIG_FILE="/workspace/configs/dev.yaml" \
    PFS_LOG_FILE="/workspace/tmp/pfs/pfs.log" \
    PFS_STATE_DIR="/workspace/tmp/pfs" \
    PFS_RUNTIME_DIR="/workspace/tmp/pfs" 

ENTRYPOINT ["/workspace/scripts/entrypoint.sh"]

CMD ["sleep", "infinity"]
