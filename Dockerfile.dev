FROM golang:1.25-trixie

RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    pkg-config \
    fuse3 \
    libfuse3-dev \
    inotify-tools \
    lcov \
    sqlite3 \
    shfmt \
    nodejs \
    npm \
    util-linux \
    e2fsprogs \
    xfsprogs \
    procps \
    git \
    make \
    bash \
    && rm -rf /var/lib/apt/lists/*

RUN go install golang.org/x/tools/cmd/goimports@latest \
    && go install github.com/air-verse/air@latest \
    && go install github.com/go-delve/delve/cmd/dlv@latest \
    && go install github.com/wadey/gocovmerge@latest \
    && go install github.com/jandelgado/gcov2lcov@latest \
    && npm install -g prettier@3

RUN curl -sSfL https://golangci-lint.run/install.sh | sh -s -- -b $(go env GOPATH)/bin v2.8.0

RUN echo "user_allow_other" >> /etc/fuse.conf

RUN mkdir -p /mnt/ssd1 /mnt/ssd2 /mnt/hdd1 /mnt/hdd2 /mnt/hdd3 \
    && mkdir -p /mnt/pfs/media \
    && mkdir -p /etc/pfs/mounts \
    && mkdir -p /var/lib/pfs-disks \
    && mkdir -p /var/lib/pfs \
    && mkdir -p /var/log/pfs \
    && mkdir -p /run/pfs \
    && touch /var/log/pfs/pfs.log

ENV PATH="/workspace/bin:/workspace/scripts:/go/bin:/usr/local/go/bin:/usr/local/bin:/usr/bin:${PATH}" \
    PFS_LOG_FILE="/var/log/pfs/pfs.log"

ENTRYPOINT ["/workspace/scripts/entrypoint.sh"]

CMD ["sleep", "infinity"]
